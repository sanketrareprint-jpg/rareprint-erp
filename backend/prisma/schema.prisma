generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(cuid())
  fullName          String
  email             String          @unique
  phone             String?
  passwordHash      String
  role              UserRole
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  commissions       Commission[]    @relation("CommissionSalesAgent")
  ordersAsAgent     Order[]         @relation("OrderSalesAgent")
  paymentsReceived  Payment[]       @relation("PaymentReceivedBy")
  productionJobs    ProductionJob[] @relation("ProductionAssignedTo")
  shipmentsHandled  Shipment[]      @relation("ShipmentHandledBy")
  statusLogsCreated StatusLog[]     @relation("StatusChangedBy")
  itemStageLogs     ItemStageLog[]  @relation("ItemStageChangedBy")
}

model Customer {
  id              String   @id @default(cuid())
  customerCode    String   @unique
  businessName    String
  contactPerson   String?
  email           String?
  phone           String?
  gstNumber       String?
  billingAddress  String?
  shippingAddress String?
  creditLimit     Decimal? @db.Decimal(12, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]
}

model ProductCategory {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  commissionRules CommissionRule[]
  products        Product[]
}

model Product {
  id                 String            @id @default(cuid())
  sku                String            @unique
  name               String
  description        String?
  categoryId         String
  gsm                Int
  sizeInches         String
  openSizeInches     String?           // e.g. "4x5" open flat size for sheet calc
  printingType       PrintingType
  sides              ProductSides
  weightPerUnitGrams Decimal?          @db.Decimal(10, 3)
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  commissionRules    CommissionRule[]
  orderItems         OrderItem[]
  category           ProductCategory   @relation(fields: [categoryId], references: [id])
  costSlabs          ProductCostSlab[]
  sheetItems         PrintSheetItem[]
}

model ProductCostSlab {
  id            String    @id @default(cuid())
  productId     String
  minQuantity   Int
  maxQuantity   Int?
  unitPrice     Decimal   @db.Decimal(12, 2)
  setupCost     Decimal?  @db.Decimal(12, 2)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, minQuantity, maxQuantity])
}

model CommissionRule {
  id             String           @id @default(cuid())
  name           String
  productId      String?
  categoryId     String?
  applicableRole UserRole         @default(SALES_AGENT)
  commissionPct  Decimal          @db.Decimal(5, 2)
  effectiveFrom  DateTime         @default(now())
  effectiveTo    DateTime?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  commissions    Commission[]
  category       ProductCategory? @relation(fields: [categoryId], references: [id])
  product        Product?         @relation(fields: [productId], references: [id])

  @@index([productId, categoryId, effectiveFrom, effectiveTo])
}

model PaymentAccount {
  id             String    @id @default(cuid())
  name           String
  accountType    String
  accountNumber  String?
  bankName       String?
  ifscCode       String?
  upiId          String?
  openingBalance Decimal?  @db.Decimal(14, 2)
  currentBalance Decimal?  @db.Decimal(14, 2)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  payments       Payment[]
}

// ── Vendor model for Clubbing / jobwork ──────────────────────────────────────
model Vendor {
  id           String        @id @default(cuid())
  name         String
  phone        String?
  email        String?
  address      String?
  gstNumber    String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  jobWorks     JobWork[]
  sheetStages  SheetStageVendor[]
}

// ── JobWork: Clubbing sub-category vendor assignment per order item ───────────
model JobWork {
  id            String      @id @default(cuid())
  orderItemId   String
  vendorId      String
  description   String
  cost          Decimal     @db.Decimal(12, 2)
  vendorInvoiceNo String?
  status        JobWorkStatus @default(PENDING)
  isPaid        Boolean     @default(false)
  paidAt        DateTime?
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItem     OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  vendor        Vendor      @relation(fields: [vendorId], references: [id])
}

// ── PrintSheet: Sheet Production ────────────────────────────────────────────
model PrintSheet {
  id            String          @id @default(cuid())
  sheetNo       String          @unique  // auto-generated e.g. SHT-2024-001
  gsm           Int
  quality       SheetQuality
  quantity      Int
  sizeInches    String          // e.g. "18x23"
  areaSqInches  Float           // computed: width * height
  printing      ProductSides
  status        SheetStatus     @default(INCOMPLETE)
  usedAreaSqInches Float        @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         PrintSheetItem[]
  stageVendors  SheetStageVendor[]
}

// ── Items placed on a sheet ──────────────────────────────────────────────────
model PrintSheetItem {
  id            String     @id @default(cuid())
  sheetId       String
  orderItemId   String
  productId     String
  multiple      Int        // how many times this item fits on sheet
  quantityOnSheet Int      // quantity covered by this sheet placement
  areaSqInches  Float      // open size area * multiple
  createdAt     DateTime   @default(now())
  sheet         PrintSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  orderItem     OrderItem  @relation(fields: [orderItemId], references: [id])
  product       Product    @relation(fields: [productId], references: [id])
}

// ── Stage-wise vendors for sheet production ──────────────────────────────────
model SheetStageVendor {
  id            String      @id @default(cuid())
  sheetId       String
  stage         SheetProductionStage
  vendorId      String
  description   String?
  cost          Decimal     @db.Decimal(12, 2)
  vendorInvoiceNo String?
  isPaid        Boolean     @default(false)
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  sheet         PrintSheet  @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  vendor        Vendor      @relation(fields: [vendorId], references: [id])
}

// ── ItemStageLog: full history of each item's stage changes ─────────────────
model ItemStageLog {
  id          String               @id @default(cuid())
  orderItemId String
  fromStage   OrderProductionStage?
  toStage     OrderProductionStage
  changedById String?
  note        String?
  createdAt   DateTime             @default(now())
  orderItem   OrderItem            @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  changedBy   User?                @relation("ItemStageChangedBy", fields: [changedById], references: [id])

  @@index([orderItemId, createdAt])
}

model Godown {
  id             String          @id @default(cuid())
  name           String
  code           String          @unique
  address        String?
  city           String?
  state          String?
  pincode        String?
  contactPerson  String?
  phone          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  productionJobs ProductionJob[]
  shipments      Shipment[]
}

model Order {
  id               String               @id @default(cuid())
  orderNumber      String               @unique
  customerId       String
  salesAgentId     String?
  orderDate        DateTime             @default(now())
  expectedDelivery DateTime?
  status           OrderStatus          @default(DRAFT)
  paymentStatus    PaymentStatus        @default(PENDING)
  subtotal         Decimal              @db.Decimal(14, 2)
  discount         Decimal              @default(0) @db.Decimal(14, 2)
  taxAmount        Decimal              @default(0) @db.Decimal(14, 2)
  shippingCharge   Decimal              @default(0) @db.Decimal(14, 2)
  grandTotal       Decimal              @db.Decimal(14, 2)
  notes            String?
  leadSource       String?              // e.g. "WALK_IN", "FB_AD_Jan_2025"
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  productionStage  OrderProductionStage @default(NOT_PRINTED)
  commissions      Commission[]
  invoice          Invoice?
  customer         Customer             @relation(fields: [customerId], references: [id])
  salesAgent       User?                @relation("OrderSalesAgent", fields: [salesAgentId], references: [id])
  items            OrderItem[]
  payments         Payment[]
  productionJobs   ProductionJob[]
  shipments        Shipment[]
  statusLogs       StatusLog[]
}

model OrderItem {
  id                  String               @id @default(cuid())
  orderId             String
  productId           String
  quantity            Int
  unitPrice           Decimal              @db.Decimal(12, 2)
  lineDiscount        Decimal              @default(0) @db.Decimal(12, 2)
  taxRatePct          Decimal              @default(0) @db.Decimal(5, 2)
  taxAmount           Decimal              @default(0) @db.Decimal(12, 2)
  lineTotal           Decimal              @db.Decimal(14, 2)
  artworkNotes        String?
  productionNotes     String?
  designFiles         Json                 @default("[]")
  productionCategory  ProductionCategory?  // INHOUSE | CLUBBING | SHEET_PRODUCTION
  itemProductionStage OrderProductionStage @default(NOT_PRINTED)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product              @relation(fields: [productId], references: [id])
  stageLogs           ItemStageLog[]
  jobWorks            JobWork[]
  sheetItems          PrintSheetItem[]

  @@index([orderId, productId])
}

model Payment {
  id               String         @id @default(cuid())
  orderId          String
  paymentAccountId String
  receivedById     String?
  paymentDate      DateTime       @default(now())
  amount           Decimal        @db.Decimal(14, 2)
  method           PaymentMethod
  referenceNumber  String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentAccount   PaymentAccount @relation(fields: [paymentAccountId], references: [id])
  receivedBy       User?          @relation("PaymentReceivedBy", fields: [receivedById], references: [id])
}

model Invoice {
  id            String    @id @default(cuid())
  orderId       String    @unique
  invoiceNumber String    @unique
  issueDate     DateTime  @default(now())
  dueDate       DateTime?
  subtotal      Decimal   @db.Decimal(14, 2)
  taxAmount     Decimal   @default(0) @db.Decimal(14, 2)
  totalAmount   Decimal   @db.Decimal(14, 2)
  paidAmount    Decimal   @default(0) @db.Decimal(14, 2)
  balanceAmount Decimal   @db.Decimal(14, 2)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Commission {
  id               String          @id @default(cuid())
  orderId          String
  salesAgentId     String
  commissionRuleId String?
  commissionPct    Decimal         @db.Decimal(5, 2)
  commissionBase   Decimal         @db.Decimal(14, 2)
  commissionAmount Decimal         @db.Decimal(14, 2)
  isSettled        Boolean         @default(false)
  settledAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  commissionRule   CommissionRule? @relation(fields: [commissionRuleId], references: [id])
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  salesAgent       User            @relation("CommissionSalesAgent", fields: [salesAgentId], references: [id])
}

model ProductionJob {
  id             String           @id @default(cuid())
  orderId        String
  godownId       String?
  assignedToId   String?
  jobCode        String           @unique
  plannedStartAt DateTime?
  actualStartAt  DateTime?
  completedAt    DateTime?
  status         ProductionStatus @default(QUEUED)
  remarks        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  assignedTo     User?            @relation("ProductionAssignedTo", fields: [assignedToId], references: [id])
  godown         Godown?          @relation(fields: [godownId], references: [id])
  order          Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Shipment {
  id               String         @id @default(cuid())
  orderId          String
  godownId         String?
  handledById      String?
  shipmentNumber   String         @unique
  dispatchDate     DateTime?
  expectedDelivery DateTime?
  deliveredAt      DateTime?
  carrierName      String?
  vehicleNumber    String?
  trackingNumber   String?
  status           ShipmentStatus @default(PENDING)
  notes            String?
  dispatchType     String?
  transportName    String?
  lrNumber         String?
  transportChargesType String?
  transportBy      String?
  awbNumber        String?
  deliveryBoyName  String?
  collectedByName  String?
  collectedByPhone String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  godown           Godown?        @relation(fields: [godownId], references: [id])
  handledBy        User?          @relation("ShipmentHandledBy", fields: [handledById], references: [id])
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model StatusLog {
  id          String       @id @default(cuid())
  orderId     String
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  changedById String?
  reason      String?
  metadata    Json?
  createdAt   DateTime     @default(now())
  changedBy   User?        @relation("StatusChangedBy", fields: [changedById], references: [id])
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  ACCOUNTS
  PRODUCTION
  DISPATCH
  SALES_AGENT
}

enum PrintingType {
  OFFSET
  DIGITAL
  SCREEN
  FLEX
}

enum ProductSides {
  SINGLE_SIDE
  DOUBLE_SIDE
}

enum OrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  IN_PRODUCTION
  READY_FOR_DISPATCH
  PENDING_DISPATCH_APPROVAL
  PARTIALLY_DISPATCHED
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  UPI
  CHEQUE
  CARD
}

enum PaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum ProductionStatus {
  QUEUED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum ShipmentStatus {
  PENDING
  PACKED
  IN_TRANSIT
  DELIVERED
  RETURNED
  CANCELLED
}

enum OrderProductionStage {
  NOT_PRINTED
  PRINTING
  PROCESSING
  READY_FOR_DISPATCH
}

// ── New enums for production overhaul ────────────────────────────────────────

enum ProductionCategory {
  INHOUSE
  CLUBBING
  SHEET_PRODUCTION
}

enum JobWorkStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum SheetQuality {
  MAPLITHO
  STICKER
  BOND
  ART_CARD
  DUPLEX_CARD_WB
  DUPLEX_CARD_GB
}

enum SheetStatus {
  INCOMPLETE
  SETTING
  PRINTING
  PROCESSING
  COMPLETE
}

enum SheetProductionStage {
  PAPER_PURCHASE
  PLATE_MAKING
  PRINTING
  BINDING
  LAMINATION
  EXTRA_PROCESSING
}